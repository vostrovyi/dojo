        {
          "name": "filterByPriceRange",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let body;",
                  "let requestName = pm.info.requestName;",
                  "",
                  "try {",
                  "    body = pm.response.json();",
                  "} catch (e) {",
                  "    body = null;",
                  "}",
                  "",
                  "pm.test(requestName +\": \"+ \"Status code is 200 OK\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(requestName +\": \"+ \"Response is an array\", function () {",
                  "    pm.expect(body).to.be.an(\"array\");",
                  "});",
                  "",
                  "pm.test(requestName +\": \"+ \"All products are within the price range (90 - 1000)\", function () {",
                  "    pm.expect(body).to.be.an('array').that.is.not.empty;",
                  "    ",
                  "    body.forEach(function(product) {",
                  "        pm.expect(product).to.have.property(\"price\").that.is.a(\"number\");",
                  "        ",
                  "        // Перевіряємо, що ціна >= 90 та <= 1000",
                  "        pm.expect(product.price).to.be.at.least(90, \"Price is lower than 90\");",
                  "        pm.expect(product.price).to.be.at.most(1000, \"Price is higher than 1000\");",
                  "    });",
                  "});",
                  "",
                  "pm.test(requestName +\": \"+ \"No products are out of bounds (< 90 or > 1000)\", function () {",
                  "    let invalidProducts = body.filter(function(product) {",
                  "        return product.price < 90 || product.price > 1000;",
                  "    });",
                  "    ",
                  "    pm.expect(invalidProducts).to.be.empty; ",
                  "    //pm.expect(invalidProducts.length).to.eql(0);",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{productsUrl}}/?price_min=90&price_max=1000",
              "host": [
                "{{productsUrl}}"
              ],
              "path": [
                ""
              ],
              "query": [
                {
                  "key": "price_min",
                  "value": "90"
                },
                {
                  "key": "price_max",
                  "value": "1000"
                }
              ]
            }
          },
