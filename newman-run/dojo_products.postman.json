        {
          "name": "pagination10",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let body;",
                  "let requestName = pm.info.requestName;",
                  "",
                  "try {",
                  "    body = pm.response.json();",
                  "} catch (e) {",
                  "    body = null;",
                  "}",
                  "",
                  "pm.test(requestName +\": \"+ \"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(requestName +\": \"+ \"Response is an array\", function () {",
                  "    pm.expect(body).to.be.an(\"array\");",
                  "});",
                  "",
                  "pm.test(requestName +\": \"+ \"Response contains exactly 10 items (limit check)\", function () {",
                  "    pm.expect(body).to.be.an(\"array\").that.has.lengthOf(10);",
                  "});",
                  "",
                  "pm.test(requestName +\": \"+ \"First product has correct data structure\", function () {",
                  "    pm.expect(body).to.not.be.empty;",
                  "    ",
                  "    let firstProduct = body[0];",
                  "    ",
                  "    // перевіряємо наявність та тип основних полів",
                  "    pm.expect(firstProduct).to.have.property(\"id\").that.is.a(\"number\");",
                  "    pm.expect(firstProduct).to.have.property(\"title\").that.is.a(\"string\");",
                  "    pm.expect(firstProduct).to.have.property(\"price\").that.is.a(\"number\");",
                  "    ",
                  "    // перевіряємо вкладені об'єкти (категорія та зображення)",
                  "    pm.expect(firstProduct).to.have.property(\"category\").that.is.an(\"object\");",
                  "    pm.expect(firstProduct.category).to.have.property(\"name\").that.is.a(\"string\");",
                  "    ",
                  "    pm.expect(firstProduct).to.have.property(\"images\").that.is.an(\"array\");",
                  "});",
                  "",
                  "pm.test(requestName +\": \"+ \"Response time is less than 1000ms\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
