        {
          "name": "createProduct",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.collectionVariables.set(\"title\", pm.variables.replaceIn('{{$randomProductName}}'));"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let body;",
                  "let requestName = pm.info.requestName;",
                  "let title = pm.collectionVariables.get(\"title\");",
                  "",
                  "try {",
                  "    body = pm.response.json();",
                  "} catch (e) {",
                  "    body = null;",
                  "}",
                  "",
                  "pm.test(requestName + \": \" + \"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(requestName + \": \" + \"Status code name has string\", function () {",
                  "    pm.response.to.have.status(\"Created\");",
                  "});",
                  "",
                  "pm.test(requestName + \": \" + \"Check response header 'Content-Type'\", function () {",
                  "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");",
                  "});",
                  "",
                  "pm.test(requestName + \": \" + \"Check price\", function () {",
                  "    pm.expect(body.price).to.eql(123);",
                  "});",
                  "",
                  "pm.collectionVariables.set(\"id\", body.id);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "protocolProfileBehavior": {
            "disabledSystemHeaders": {}
          },
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"{{title}}\",\n  \"slug\": \"handmade-fresh-table\",\n  \"price\": 123,\n  \"description\": \"Andy shoes are designed to keeping in...\",\n  \"categoryId\": 1,\n  \"images\": [\n    \"https://placehold.co/600x400\"\n  ]\n}",
              "options": {
